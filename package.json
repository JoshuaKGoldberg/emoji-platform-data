{
	"name": "emoji-platform-data",
	"version": "0.1.0",
	"description": "Static export of platform-specific metadata for unicode emojis. 🗝️",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/JoshuaKGoldberg/emoji-platform-data.git"
	},
	"license": "MIT",
	"author": {
		"name": "Josh Goldberg",
		"email": "npm@joshuakgoldberg.com"
	},
	"type": "module",
	"exports": {
		".": "./lib/index.mjs",
		"./by-emoji.json": "./lib/by-emoji.json",
		"./by-title.json": "./lib/by-title.json"
	},
	"files": [
		"LICENSE.md",
		"README.md",
		"lib/",
		"package.json"
	],
	"scripts": {
		"build": "tsx src/buildData.ts",
		"format": "prettier .",
		"lint": "eslint . --max-warnings 0",
		"lint:knip": "knip",
		"lint:md": "markdownlint \"**/*.md\" \".github/**/*.md\" --rules sentences-per-line",
		"lint:packages": "pnpm dedupe --check",
		"lint:spelling": "cspell \"**\" \".github/**/*\"",
		"prepare": "husky",
		"tsc": "tsc"
	},
	"lint-staged": {
		"*": "prettier --ignore-unknown --write"
	},
	"dependencies": {
		"emojipedia": "^0.4.0"
	},
	"devDependencies": {
		"@eslint-community/eslint-plugin-eslint-comments": "4.7.0",
		"@eslint/js": "9.39.1",
		"@release-it/conventional-changelog": "11.0.0",
		"@types/eslint-plugin-markdown": "2.0.2",
		"@types/node": "24.13.3",
		"change-case": "5.4.4",
		"create-typescript-app": "2.16.2",
		"cspell": "10.0.0",
		"eslint": "9.39.1",
		"eslint-plugin-jsdoc": "62.9.0",
		"eslint-plugin-jsonc": "3.3.0",
		"eslint-plugin-markdown": "5.1.0",
		"eslint-plugin-n": "17.16.2",
		"eslint-plugin-package-json": "0.54.0",
		"eslint-plugin-perfectionist": "5.10.0",
		"eslint-plugin-regexp": "3.1.0",
		"eslint-plugin-yml": "3.6.0",
		"fast-glob": "3.3.3",
		"fluemoji": "git+https://github.com/microsoft/fluentui-emoji.git",
		"gemoji": "8.1.0",
		"husky": "9.1.7",
		"knip": "6.26.0",
		"lint-staged": "17.0.2",
		"markdownlint": "0.41.0",
		"markdownlint-cli": "0.49.0",
		"prettier": "3.9.5",
		"prettier-plugin-curly": "0.4.0",
		"prettier-plugin-packagejson": "3.0.0",
		"prettier-plugin-sh": "0.19.0",
		"release-it": "20.2.1",
		"sentences-per-line": "0.3.0",
		"title-case": "4.3.2",
		"tsx": "4.23.0",
		"typescript": "5.9.2",
		"typescript-eslint": "8.41.0",
		"yaml": "2.9.0"
	},
	"packageManager": "pnpm@10.34.5",
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"provenance": true
	}
}
